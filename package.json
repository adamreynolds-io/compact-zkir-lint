{
  "name": "zkir-lint",
  "version": "0.1.0",
  "description": "Find Compact circuit bugs before your users do. Detects JS/ZK divergence patterns where compact-runtime succeeds but proof validation fails.",
  "type": "module",
  "bin": {
    "zkir-lint": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "tsx src/cli.ts"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "compact",
    "midnight",
    "zkir",
    "zk",
    "lint",
    "static-analysis",
    "proof-server",
    "zero-knowledge"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/adamreynolds-io/compact-zkir-lint.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
